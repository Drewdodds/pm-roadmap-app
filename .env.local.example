# Copy to .env.local (gitignored) and fill in.
# .env.local is read by vite.config.ts in Node — values never enter the browser bundle.

# Notion internal integration token. Create at https://www.notion.so/profile/integrations
# Then in the Hopper DB → ··· → Connections → add the integration.
NOTION_TOKEN=secret_xxx

# Notion DB IDs (safe to expose to the browser — auth is per-token, not per-URL).
VITE_NOTION_HOPPER_DB_ID=270f2b415dd080e697b8f2aae75fa40a
